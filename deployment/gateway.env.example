# NarrowCTI gateway deployment template.
# Copy this file to a local, non-versioned env file before adding real secrets.

OPENCTI_URL=http://opencti:8080
OPENCTI_TOKEN=replace-with-opencti-token
OTX_API_KEY=replace-with-otx-api-key
MISP_URL=http://misp-core
MISP_KEY=replace-with-misp-api-key

CONNECTOR_NAME=NarrowCTI Gateway
CONNECTOR_RUN_INTERVAL=3600

NARROWCTI_MODE=gateway
NARROWCTI_ENABLED_SOURCES=otx
NARROWCTI_DRY_RUN=true
NARROWCTI_RUN_ONCE=true
NARROWCTI_SOURCE_INTERVAL_SECONDS=300
NARROWCTI_STATE_DIR=/app/state
NARROWCTI_DECISION_AUDIT_DIR=/app/state/audit
NARROWCTI_RUN_SUMMARY_FILE=/app/state/gateway_runs.jsonl

NARROWCTI_MIN_SCORE_TO_INGEST=60
NARROWCTI_ENABLE_QUARANTINE=true
NARROWCTI_QUARANTINE_SCORE_THRESHOLD=50
NARROWCTI_MAX_DAYS_OLD=1095
NARROWCTI_ALLOWED_TLP=white,green
NARROWCTI_ALLOWED_INDICATOR_TYPES=ipv4,ipv6,domain,hostname,url,email,filehash-md5,filehash-sha1,filehash-sha256

NARROWCTI_DEDUP_MODE=hybrid
NARROWCTI_DEDUP_STATE_FILE=/app/state/dedup_index.json
NARROWCTI_OPENCTI_DEDUP_LOOKUP=false

NARROWCTI_QUARANTINE_REPOSITORY=/app/state/quarantine.jsonl
NARROWCTI_QUARANTINE_RAW_SNAPSHOT_MAX_BYTES=65536
NARROWCTI_RELEASE_AUDIT_FILE=/app/state/audit/releases.jsonl
NARROWCTI_RELEASE_QUARANTINE_REQUIRES_REASON=true
NARROWCTI_REVIEWER=operator

NARROWCTI_ENABLE_OTX_ENTITY_EXTRACTION=true
NARROWCTI_ENABLE_MITRE_ATTACK_RESOLUTION=true
NARROWCTI_MITRE_CACHE_FILE=/app/state/mitre_attack_cache.json
NARROWCTI_MITRE_STIX_URL=https://raw.githubusercontent.com/mitre-attack/attack-stix-data/master/enterprise-attack/enterprise-attack.json

NARROWCTI_MIN_ENTITY_CONFIDENCE=0
NARROWCTI_MIN_RELATIONSHIP_CONFIDENCE=0
NARROWCTI_REQUIRE_RELATIONSHIP_PROVENANCE=false
NARROWCTI_ALLOWED_GRAPH_ENTITY_TYPES=
NARROWCTI_ALLOWED_GRAPH_STIX_OBJECT_TYPES=
NARROWCTI_GRAPH_EXPORT_MODE=audit
NARROWCTI_GRAPH_DEDUP_STATE_FILE=
NARROWCTI_OPENCTI_GRAPH_LOOKUP=false

NARROWCTI_LICENSE_EDITION=evaluation
NARROWCTI_LICENSE_CUSTOMER_ID=
NARROWCTI_LICENSE_FILE=
NARROWCTI_LICENSED_CAPABILITIES=
NARROWCTI_FEATURE_GATES_ENFORCED=false

OTX_QUERIES=lummac2,stealc,infostealer campaign
OTX_TIMEOUT=60
OTX_SEARCH_TIMEOUT=45
OTX_RETRIES=3
OTX_RETRY_BACKOFF_SECONDS=3
OTX_DRY_RUN=true
MAX_PULSES_PER_QUERY=5
MAX_SEARCH_RESULTS_PER_QUERY=10
MAX_IOCS_PER_PULSE=2000
OTX_SOURCE_CONFIDENCE=50
STATE_FILE=/app/state/otx_state.json
DECISION_AUDIT_FILE=/app/state/audit/otx_decisions.jsonl
OTX_QUARANTINE_REPOSITORY=/app/state/quarantine.jsonl

MISP_QUERIES=*
MISP_VERIFY_TLS=false
MISP_DRY_RUN=true
MISP_RUN_ONCE=true
MISP_FROM_DATE=
MISP_TO_DATE=
MISP_TAGS=tlp:green
MISP_PUBLISHED_ONLY=true
MISP_MAX_EVENTS_PER_RUN=1
MISP_MAX_ATTRIBUTES_PER_EVENT=1000
MISP_MAX_IOCS_PER_EVENT=1000
MISP_OVERSIZED_EVENT_ACTION=skip
MISP_SOURCE_CONFIDENCE=50
MISP_STATE_FILE=/app/state/misp_state.json
MISP_DECISION_AUDIT_FILE=/app/state/audit/misp_decisions.jsonl
MISP_QUARANTINE_REPOSITORY=/app/state/quarantine.jsonl

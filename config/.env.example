OPENCTI_URL=http://opencti:8080
OPENCTI_TOKEN=change-me
OTX_API_KEY=change-me
CONNECTOR_NAME=NarrowCTI Gateway

OTX_QUERIES=lummac2,stealc,rhadamanthys,meduza stealer,redline stealer,vidar stealer,darkgate,remcos,cobalt strike
OTX_TIMEOUT=60
OTX_SEARCH_TIMEOUT=45
OTX_RETRIES=3
OTX_RETRY_BACKOFF_SECONDS=3
CONNECTOR_RUN_INTERVAL=3600

MAX_PULSES_PER_QUERY=5
MAX_SEARCH_RESULTS_PER_QUERY=10
MAX_IOCS_PER_PULSE=2000

# Set to 0 to disable the hard age cutoff and let scoring decide.
MAX_DAYS_HARD_FILTER=0
MAX_DAYS_OLD=1095
MIN_SCORE_FOR_OLD_PULSE=80
MIN_SCORE_TO_INGEST=60

ENABLE_QUARANTINE=true
QUARANTINE_SCORE_THRESHOLD=50

STATE_FILE=/app/state/state.json

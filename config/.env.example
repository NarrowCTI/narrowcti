OPENCTI_URL=http://opencti:8080
OPENCTI_TOKEN=change-me
OTX_API_KEY=change-me
CONNECTOR_NAME=NarrowCTI Gateway

OTX_QUERIES=lummac2,stealc,rhadamanthys,meduza stealer,redline stealer,vidar stealer,darkgate,remcos,cobalt strike
OTX_TIMEOUT=60
OTX_SEARCH_TIMEOUT=45
OTX_RETRIES=3
OTX_RETRY_BACKOFF_SECONDS=3
CONNECTOR_RUN_INTERVAL=3600

MAX_PULSES_PER_QUERY=5
MAX_SEARCH_RESULTS_PER_QUERY=10
MAX_IOCS_PER_PULSE=2000

# Set to 0 to disable the hard age cutoff and let scoring decide.
MAX_DAYS_HARD_FILTER=0
MAX_DAYS_OLD=1095
MIN_SCORE_FOR_OLD_PULSE=80
MIN_SCORE_TO_INGEST=60
OTX_SOURCE_CONFIDENCE=50

ENABLE_QUARANTINE=true
QUARANTINE_SCORE_THRESHOLD=50

STATE_FILE=/app/state/state.json
OTX_DRY_RUN=true
# NarrowCTI gateway runtime controls
NARROWCTI_MODE=gateway
NARROWCTI_ENABLED_SOURCES=otx
NARROWCTI_DRY_RUN=true
NARROWCTI_RUN_ONCE=true
NARROWCTI_SOURCE_INTERVAL_SECONDS=300
# Used by the gateway to derive source-scoped defaults such as otx_state.json
# and misp_state.json when source-specific state variables are not set.
NARROWCTI_STATE_DIR=/app/state
# Used by the gateway to derive source-scoped decision audit files when
# DECISION_AUDIT_FILE or MISP_DECISION_AUDIT_FILE are not set.
NARROWCTI_DECISION_AUDIT_DIR=/app/state/audit
NARROWCTI_RUN_SUMMARY_FILE=/app/state/gateway_runs.jsonl
NARROWCTI_MIN_SCORE_TO_INGEST=60
NARROWCTI_ENABLE_QUARANTINE=true
NARROWCTI_QUARANTINE_SCORE_THRESHOLD=50
NARROWCTI_MAX_DAYS_OLD=1095
# source keeps only per-source state; artifact/hybrid also record artifact sightings.
NARROWCTI_DEDUP_MODE=source
# Enables optional OpenCTI STIX Indicator pattern lookup before export.
NARROWCTI_OPENCTI_DEDUP_LOOKUP=false
# Stores artifact_fingerprints and artifact_records when artifact/hybrid is enabled.
NARROWCTI_DEDUP_STATE_FILE=/app/state/dedup_index.json
